{
  "name": "micarnet",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @micarnet/db db:push",
    "db:studio": "turbo -F @micarnet/db db:studio",
    "db:generate": "turbo -F @micarnet/db db:generate",
    "db:migrate": "turbo -F @micarnet/db db:migrate",
    "db:start": "turbo -F @micarnet/db db:start",
    "db:watch": "turbo -F @micarnet/db db:watch",
    "db:stop": "turbo -F @micarnet/db db:stop",
    "db:down": "turbo -F @micarnet/db db:down",
    "prepare": "husky"
  },
  "dependencies": {
    "@micarnet/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@micarnet/config": "workspace:*",
    "@types/node": "^22.13.14",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "turbo": "^2.6.3",
    "typescript": "catalog:",
    "ultracite": "7.0.5"
  },
  "packageManager": "pnpm@11.0.8",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "pnpm dlx ultracite fix"
    ]
  }
}
